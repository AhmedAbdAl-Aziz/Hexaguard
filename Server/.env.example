# MongoDB
MONGO_URI=mongodb://localhost:27017/hexaguard

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-key

# Scraper API Token (used to authenticate POST /api/cves from crawler scripts)
SCRAPER_API_TOKEN=change-this-scraper-token

# CORS - Frontend origin
FRONTEND_ORIGIN=http://localhost:5173

# Flask
FLASK_ENV=development
FLASK_DEBUG=1

# Email (SMTP) - optional, for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
